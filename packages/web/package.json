{
  "name": "@jewellery-catalogue/web",
  "version": "1.7.0",
  "scripts": {
    "start:dev": "vite --port 3000",
    "start:mock-auth": "node mock-auth-server.js",
    "start": "yarn start:dev",
    "start:with-mock": "concurrently \"yarn start:mock-auth\" \"yarn start:dev\"",
    "build": "vite build --emptyOutDir",
    "pw:install": "PLAYWRIGHT_BROWSERS_PATH=~/.cache/ms-playwright playwright install --with-deps",
    "pw:run": "playwright test --config=playwright.config.ts",
    "pw:e2e": "playwright test --config=playwright.config.ts",
    "pw:e2e:local": "playwright test --config=playwright.config.ts",
    "pw:e2e:staging": "NODE_ENV=staging playwright test --config=playwright.config.ts",
    "pw:e2e:headed": "playwright test --config=playwright.config.ts --headed",
    "pw:e2e:debug": "playwright test --config=playwright.config.ts --debug",
    "pw:open": "playwright test --config=playwright.config.ts --ui",
    "preview": "vite preview"
  },
  "dependencies": {
