{
  "name": "jewellery-catalogue",
  "private": true,
  "repository": "https://github.com/igor-siergiej/jewellery-catalogue",
  "author": "Igor Siergiej <igorsiergiej@gmail.com>",
  "scripts": {
    "start:web": "dotenv -e .env -- bun run --filter @jewellery-catalogue/web start",
    "start:web:with-mock": "dotenv -e .env -- bun run --filter @jewellery-catalogue/web start:with-mock",
    "start:api": "dotenv -e .env -- bun run --filter @jewellery-catalogue/api start",
    "start": "concurrently \"bun run start:web\" \"bun run start:api\"",
    "start:with-mock": "concurrently \"bun run start:web:with-mock\" \"bun run start:api\"",
    "lint": "biome check .",
    "lint:fix": "biome check --fix --unsafe .",
    "format": "biome format --write .",
    "prepare": "husky",
    "release": "semantic-release"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.2.5",
    "@imapps/biome-config": "0.5.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^8.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.0",
    "semantic-release": "^24.2.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.4"
  },
  "packageManager": "bun@1",
  "version": "1.14.1",
  "lint-staged": {
    "*.{ts,tsx,json}": "biome check --fix --unsafe"
  }
}
