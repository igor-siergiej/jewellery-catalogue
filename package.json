{
  "name": "jewellery-catalogue",
  "private": true,
  "repository": "git@gitlab.com:imapps/jewellery-catalogue.git",
  "author": "Igor Siergiej <igorsiergiej@gmail.com>",
  "scripts": {
    "start:web": "dotenv -e .env -- yarn workspace @jewellery-catalogue/web start",
    "start:web:with-mock": "dotenv -e .env -- yarn workspace @jewellery-catalogue/web start:with-mock",
    "start:api": "dotenv -e .env -- yarn workspace @jewellery-catalogue/api start",
    "start": "yarn start:web & yarn start:api",
    "start:with-mock": "yarn start:web:with-mock & yarn start:api",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "prepare": "husky"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@imapps/eslint-config": "^0.1.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.30.1",
    "eslint-plugin-mui-path-imports": "^0.0.15",
    "eslint-plugin-use-encapsulation": "^1.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.0",
    "semantic-release": "^24.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vite-node": "^3.2.4"
  },
  "packageManager": "yarn@4.9.2",
  "version": "1.4.0",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
